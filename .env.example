# Telegram bot token (получить у @BotFather)
BOT_TOKEN=your_token_here

# Список Telegram ID администраторов через запятую
# (свой ID можно узнать у @userinfobot)
ADMIN_IDS=123456789

# База данных.
# Дев/демо (по умолчанию): sqlite+aiosqlite:///./bot.db
# Прод: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# Часовой пояс заведения (важно для слотов и напоминаний)
TIMEZONE=Europe/Moscow

# ── Webhook (прод). По умолчанию выключен — используется polling ──────
USE_WEBHOOK=false
# Публичный https-адрес сервера (без пути), напр. https://example.com
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
# Секрет для проверки заголовка X-Telegram-Bot-Api-Secret-Token (сгенерировать любую случайную строку)
WEBHOOK_SECRET=
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

# ── Наблюдаемость (опционально) ────────────────────────────────────────
# Путь к файлу лога с ротацией. Пусто — лог только в консоль/docker logs.
LOG_FILE=
# true — структурированные JSON-логи (для ELK/Loki/CloudWatch). По умолчанию — текстом.
LOG_JSON=false
# DSN проекта в Sentry. Пусто — Sentry не подключается.
SENTRY_DSN=
# /metrics (Prometheus) доступен всегда на WEB_SERVER_PORT, отдельного флага не требует.

# Пароль Postgres для docker-compose (используется в docker-compose.yml)
POSTGRES_PASSWORD=barber

# ── Бэкапы Postgres (сервис "backup" в docker-compose) ──────────────────
# Как часто делать pg_dump, секунды. По умолчанию — раз в сутки.
BACKUP_INTERVAL_SECONDS=86400
# Сколько дней хранить старые бэкапы (старше — удаляются).
BACKUP_RETENTION_DAYS=7
